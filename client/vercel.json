{
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://nclex-keys-international.onrender.com/api/:match*"
    }
  ],
  "headers": [
    {
      "source": "/api/:match*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
